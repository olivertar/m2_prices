<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="breeze.js">
            <arguments>
                <argument name="bundles" xsi:type="array">
                    <item name="default" xsi:type="array">
                        <item name="items" xsi:type="array">
                            <item name="b2bPricesCore" xsi:type="array">
                                <item name="path" xsi:type="string">Orangecat_Prices/js/b2b-prices-core</item>
                                <item name="load" xsi:type="array">
                                    <item name="onDom" xsi:type="array">
                                        <item name="body" xsi:type="string">body</item>
                                    </item>
                                </item>
                            </item>
                            <item name="Orangecat_Prices/js/breeze/prices-mixins" xsi:type="array">
                                <item name="path" xsi:type="string">Orangecat_Prices/js/breeze/prices-mixins</item>
                                <item name="mixins" xsi:type="array">
                                    <item name="configurable" xsi:type="string">configurable</item>
                                    <item name="SwatchRenderer" xsi:type="string">Magento_Swatches/js/swatch-renderer</item>
                                    <item name="priceBox" xsi:type="string">Magento_Catalog/js/price-box</item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
